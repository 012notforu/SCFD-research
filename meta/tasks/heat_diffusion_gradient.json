{
  "task": "heat_diffusion_gradient",
  "domain": "heat_diffusion",
  "description": "SCFD-controlled heat equation steering on a 96x96 grid toward a linear gradient target.",
  "simulator": {
    "module": "benchmarks.heat_diffusion",
    "params": {
      "shape": [
        96,
        96
      ],
      "dt": 0.1,
      "noise": 0.01
    }
  },
  "target": {
    "kind": "gradient",
    "generator": "synthetic_temperature"
  },
  "controller": {
    "type": "SCFD_boundary_modulation",
    "config_fields": [
      "encode_gain",
      "encode_decay",
      "control_gain",
      "control_clip",
      "smooth_lambda",
      "theta_clip",
      "alpha"
    ]
  },
  "optimizer_run": {
    "script": "run.train_cma_heat",
    "outdir": "runs/heat_diffusion_cma_large",
    "generations": 40,
    "population": 12,
    "elite": 3,
    "episodes": 4,
    "steps": 1500,
    "record_interval": 100,
    "base_seed": 0
  },
  "artifacts": {
    "raster": "runs/heat_diffusion_cma_large/best_artifact/heat_diffusion_target_vs_actual.png",
    "history": "runs/heat_diffusion_cma_large/best_artifact/heat_diffusion_history.npz"
  },
  "vector_path": "meta/vectors/heat_diffusion/2025-09-29_large.json"
}