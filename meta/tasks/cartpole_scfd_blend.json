    "population": 10,
    "elite": 3,
    "episodes": 3,
    "steps": 2500,
    "base_seed": 0
  },
  "artifacts": {
    "history": "runs/scfd_cma_half/history.csv"
  },
  "vector_path": "meta/vectors/cartpole/2025-09-29_half.json"
}