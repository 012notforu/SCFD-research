{
  "task": "cartpole_scfd_blend",
  "domain": "cartpole_control",
  "description": "SCFD blended linear/ternary controller balancing the cart-pole benchmark for 2500 steps.",
  "controller": {
    "module": "benchmarks.scfd_cartpole",
    "config_fields": [
      "feature_weights",
      "policy_bias",
      "blend_linear_weight",
      "blend_ternary_weight",
      "ternary_force_scale",
      "ternary_smooth_lambda"
    ]
  },
  "optimizer_run": {
    "script": "run.train_cma_scfd",
