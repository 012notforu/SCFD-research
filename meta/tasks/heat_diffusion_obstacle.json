{
  "task": "heat_diffusion_obstacle",
  "domain": "heat_diffusion",
  "variant": "obstacle",
  "description": "Hot-corner objective with interior obstacle, per-step control budget, and corner-tracking metrics.",
  "simulator": {
    "module": "benchmarks.heat_diffusion_obstacle",
    "params": {
      "shape": [96, 96],
      "dt": 0.1,
      "control_budget": 6.0,
      "gap_height": 6,
      "gap_width": 4,
      "obstacle_temperature": 0.05,
      "noise": 0.01
    }
  },
  "target": {
    "kind": "hot_corner",
    "generator": "synthetic_obstacle_target"
  },
  "controller": {
    "type": "SCFD_boundary_modulation",
    "config_fields": [
      "encode_gain",
      "encode_decay",
      "control_gain",
      "control_clip",
      "smooth_lambda",
      "theta_clip",
      "alpha"
    ],
    "scfd_cfg": "cfg/defaults.yaml"
  },
  "optimizer_run": {
    "script": "run.train_cma_heat_obstacle",
    "outdir": "runs/heat_obstacle_cma",
    "generations": 30,
    "population": 9,
    "elite": 3,
    "episodes": 3,
    "steps": 1500,
    "record_interval": 75,
    "base_seed": 0
  },
  "artifacts": {
    "raster": "runs/heat_obstacle_cma/best_artifact/heat_diffusion_target_vs_actual.png",
    "history": "runs/heat_obstacle_cma/best_artifact/heat_diffusion_history.npz",
    "mask": "runs/heat_obstacle_cma/best_artifact/heat_obstacle_mask.png"
  },
  "vector_path": "meta/vectors/heat_diffusion/2025-10-01_obstacle_hotcorner.json",
  "benchmark_metrics": {
    "status": "pending"
  }
}
